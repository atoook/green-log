DATABASE_URL=sqlite:///./green_log.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173
CLERK_WEBHOOK_SECRET=
LEGACY_OWNER_BACKFILL_USER_ID=

# Object storage settings for S3-compatible providers.
# Common: set these for both Amazon S3 and Cloudflare R2.
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=ap-northeast-1
STORAGE_BUCKET_NAME=

# Amazon S3: leave STORAGE_ENDPOINT_URL empty.
# Cloudflare R2: set https://<account_id>.r2.cloudflarestorage.com and use STORAGE_REGION=auto.
STORAGE_ENDPOINT_URL=

# Common: public base URL for image display.
# Amazon S3 example: https://<bucket>.s3.<region>.amazonaws.com
# Cloudflare R2 example: https://<custom-domain>
STORAGE_PUBLIC_BASE_URL=
